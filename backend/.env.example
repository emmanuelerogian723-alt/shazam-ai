# ════════════════════════════════════════════════════════════════
#  SHAZAM AI — Environment Variables
#  Copy to .env and fill in your real values
#  NEVER commit .env to git
# ════════════════════════════════════════════════════════════════

# ── App ──────────────────────────────────────────────────────────
APP_NAME=SHAZAM AI
ENVIRONMENT=development
DEBUG=true
SECRET_KEY=generate-with-openssl-rand-hex-32

# ── Database (Neon.tech free tier) ───────────────────────────────
DATABASE_URL=postgresql+asyncpg://user:pass@host/shazam_ai

# ── Redis (Upstash free tier) ────────────────────────────────────
REDIS_URL=redis://default:password@host:6379

# ── Qdrant (Qdrant Cloud free tier) ──────────────────────────────
QDRANT_URL=https://your-cluster.qdrant.io
QDRANT_API_KEY=your_qdrant_api_key

# ════════════════════════════════════════════════════════════════
#  AI PROVIDERS — Add the ones you have. System auto-falls back.
# ════════════════════════════════════════════════════════════════

# ── GROQ (FREE — get key at console.groq.com) ────────────────────
# Gives you: llama-3.3-70b, llama-3.1-8b, whisper-large-v3-turbo, playai-tts
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── OPENROUTER (FREE models available — openrouter.ai) ───────────
# Free models: meta-llama/llama-3.3-70b:free, deepseek/deepseek-r1:free
# mistralai/mistral-7b:free, qwen/qwen-2.5-coder-32b:free
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── OPTIONAL PAID PROVIDERS (only needed for premium features) ────
# OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxx
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx
# GEMINI_API_KEY=AIzaxxxxxxxxxxxxxxxxxxxx

# ── IMAGE GENERATION (FREE options) ──────────────────────────────
# Pollinations.ai is enabled by default — NO KEY NEEDED, completely free
POLLINATIONS_ENABLED=true

# HuggingFace — free tier available (get at huggingface.co/settings/tokens)
# HUGGINGFACE_API_KEY=hf_xxxxxxxxxxxxxxxxxxxx

# ── VOICE / TTS ───────────────────────────────────────────────────
# Groq PlayAI TTS is FREE with your GROQ_API_KEY above
# ElevenLabs free tier = 10,000 chars/month (elevenlabs.io)
# ELEVENLABS_API_KEY=your_elevenlabs_key

# ── WEB SEARCH (serper.dev — 2500 free searches/month) ───────────
SERPER_API_KEY=your_serper_api_key

# ── TELEGRAM ─────────────────────────────────────────────────────
# Get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=1234567890:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TELEGRAM_WEBHOOK_URL=https://your-domain.com/api/v1/telegram/webhook

# ── STORAGE (Cloudflare R2 free tier or AWS S3) ───────────────────
# STORAGE_ENDPOINT=https://account.r2.cloudflarestorage.com
# STORAGE_BUCKET=shazam-ai-uploads
# STORAGE_ACCESS_KEY=your_access_key
# STORAGE_SECRET_KEY=your_secret_key
